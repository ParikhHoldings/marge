# Marge — AI Pastoral Assistant
# Copy this file to .env and fill in your values.

# Rock RMS API key (leave blank to run in standalone mode without Rock)
ROCK_HALLMARK_API_KEY=

# Database connection string
# SQLite (local dev):  sqlite:///./marge.db
# Postgres (prod):     postgresql://user:password@host:5432/marge
DATABASE_URL=sqlite:///./marge.db

# Pastor and church identity (used in all message drafts and briefings)
PASTOR_NAME=Nathan
CHURCH_NAME=Hallmark Church
DEFAULT_CHURCH_ID=hallmark

# Auth (required for protected API routes)
# Option A: JWT bearer auth
AUTH_JWT_SECRET=replace-with-long-random-secret
# AUTH_JWT_ALGORITHMS=HS256
# AUTH_JWT_ISSUER=
# AUTH_JWT_AUDIENCE=

# Option B: session token auth (local/dev convenience)
# Format: token|role|church_id|user_id,token|role|church_id|user_id
AUTH_SESSION_TOKENS=dev-pastor|pastor|hallmark|nathan

# Telegram delivery (optional)
# Get TELEGRAM_BOT_TOKEN from BotFather: https://t.me/botfather
# Get TELEGRAM_CHAT_ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Rock RMS base URL (override only if your Rock instance has a different domain)
# ROCK_BASE_URL=https://rock.hbcfw.org/api/v2

# Marge behavior tuning (all optional — defaults shown)
# ABSENCE_THRESHOLD_DAYS=21       # Days absent before flagging in briefing
# CARE_OVERDUE_DAYS=7             # Days since last care contact before surfacing
# PRAYER_OVERDUE_DAYS=14          # Days since prayer request before follow-up nudge
# VISITOR_FOLLOWUP_DELAY_HOURS=48 # Hours after visit before Day-1 follow-up surfaces
# BIRTHDAY_LOOKAHEAD_DAYS=7       # How many days ahead to look for birthdays/anniversaries
# NUDGE_LOOKBACK_DAYS=14          # Minimum days of silence before generating a nudge

# CORS (optional — leave as * for local dev)
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
